# Скопируйте в .env на сервере (не коммитьте .env).
POSTGRES_PASSWORD=change-me-long-random
SECRET_KEY=change-me-long-random
ADMIN_PASSWORD=change-me-admin-login
# Опционально: Bearer / X-Api-Key для /api/v1/*
API_TOKEN=
SESSION_COOKIE_HTTPS_ONLY=false
# production — отключает /docs и требует сильные SECRET_KEY / ADMIN_PASSWORD
APP_ENV=development
# CSRF и security headers (по умолчанию включены)
# CSRF_ENABLED=true
# SECURITY_HEADERS_ENABLED=true
# Лимит запросов /api/v1 с одного IP в минуту (0 = без лимита)
# API_RATE_LIMIT_PER_MINUTE=300
